{
  "name": "backend-template",
  "version": "1.0.0",
  "description": "Template modular: Bun + Fastify + Zod + TypeORM + Postgres",
  "module": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch run src/server.ts",
    "start": "bun run src/server.ts",
    "start:migrate": "bun run src/database/run-migrations.ts && bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typeorm": "bunx --bun typeorm -d src/database/data-source.ts",
    "migration:generate": "bun run typeorm migration:generate src/database/migrations/Migration",
    "migration:create": "bunx --bun typeorm migration:create src/database/migrations/Migration",
    "migration:run": "bun run typeorm migration:run",
    "migration:revert": "bun run typeorm migration:revert"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.41",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "unplugin-swc": "^1.5.9",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "trustedDependencies": [
    "@swc/core"
  ]
}
