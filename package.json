{
  "name": "backend-template",
  "version": "1.0.0",
  "description": "Template modular: Bun + Fastify + Zod + TypeORM + Postgres",
  "module": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch run src/server.ts",
    "start": "bun run src/server.ts",
    "start:migrate": "bun run src/database/run-migrations.ts && bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typeorm": "bunx typeorm -d src/database/data-source.ts",
    "migration:generate": "bun run typeorm migration:generate src/database/migrations/Migration",
    "migration:create": "bunx typeorm migration:create src/database/migrations/Migration",
    "migration:run": "bun run typeorm migration:run",
    "migration:revert": "bun run typeorm migration:revert"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}