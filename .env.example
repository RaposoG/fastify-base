# App
NODE_ENV=development
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info

# Database
# Opção 1 (preferida): URL única
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/app_db

# Opção 2: variáveis discretas (usadas apenas se DATABASE_URL não estiver definida)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=app_db

# Comum
DB_SSL=false
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Cookies / CORS / CSRF
COOKIE_SECRET=change-me-cookie-secret-please-32-bytes
# COOKIE_DOMAIN=.example.com
COOKIE_SECURE=false

# Origens autorizadas (CSV). Necessário com cookies + credentials.
CORS_ORIGIN=http://localhost:3000
